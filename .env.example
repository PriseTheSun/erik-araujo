# GEMINI_API_KEY: Necessário para chamadas da API Gemini AI.
# Obtenha sua chave em: https://aistudio.google.com/app/apikey (opcional)
GEMINI_API_KEY="SUA_CHAVE_AQUI"

# APP_URL: A URL onde esta aplicação está hospedada.
# Usada para links auto-referenciais, callbacks de OAuth e endpoints de API.
APP_URL="http://localhost:3000"

